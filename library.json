{
  "name": "ESP32_Hardware",
  "version": "1.0.0",
  "description": "Library for common hardware mounted on PAMI and main robot",
  "keywords": [
    "esp32",
    "hardware",
    "robotics",
    "pami",
    "servo",
    "screen",
    "IHM",
    "INA219"
  ],
  "homepage": "https://github.com/Mecapitronic/ESP32_Hardware",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mecapitronic/ESP32_Hardware.git"
  },
  "authors": [
    {
      "name": "Mecapitronic",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": [
    "arduino"
  ],
  "platforms": [
    "espressif32"
  ],
  "dependencies": [
    {
      "name": "robotis-git/Dynamixel2Arduino",
      "version": "^0.8.0"
    },
    {
      "name": "adafruit/Adafruit SSD1306",
      "version": "^2.5.16"
    },
    {
      "name": "adafruit/Adafruit INA219",
      "version": "^1.2.3"
    },
    {
      "name": "fastled/FastLED",
      "version": "3.9.16"
    }
  ],
  "build": {
    "includeDir": "include",
    "srcDir": "src"
  },
  "examples": [
    "examples/*/*.cpp"
  ]
}